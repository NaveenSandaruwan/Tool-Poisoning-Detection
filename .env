# Environment configuration for model deployment

# Model version
MODEL_VERSION=v2

# Model path (can be overridden per service)
MODEL_PATH=poison_detection_model_v2

# Resource limits
CPU_LIMIT=1.0
MEMORY_LIMIT=2G

# Port configuration (internal)
MODEL_PORT=8000

# Nginx configuration
NGINX_PORT=80
NGINX_SSL_PORT=443

# Rate limiting (requests per second)
RATE_LIMIT=10
BATCH_RATE_LIMIT=2

# Logging
LOG_LEVEL=INFO
